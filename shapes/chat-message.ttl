@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://solidproject.org/shapes/chatchannel#> a sh:NodeShape ;
    rdfs:label "Message Shape" ;
    rdfs:comment "SHACL NodeShape defining constraints for messages in Solid Chat." ;
    sh:property [ rdfs:label "Created Date" ;
            rdfs:comment "The date and time when the message was created." ;
            sh:datatype xsd:dateTime ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dcterms:created ],
        [ rdfs:label "Message Author" ;
            rdfs:comment "The agent or person who authored the message." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path foaf:maker ],
        [ rdfs:label "Message Content" ;
            rdfs:comment "The textual content of the message." ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://rdfs.org/sioc/ns#content> ],
        [ rdfs:label "Related Chat" ;
            rdfs:comment "The chat channel or conversation to which this message belongs." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path [ sh:inversePath <http://www.w3.org/2005/01/wf/flow#message> ] ] ;
    sh:targetObjectsOf <http://www.w3.org/2005/01/wf/flow#message> .

