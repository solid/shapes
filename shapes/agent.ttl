@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix person-shape: <https://solidproject.org/shapes/person#> .
@prefix software-agent-shape: <https://solidproject.org/shapes/softwareAgent#> .
@prefix organization-shape: <https://solidproject.org/shapes/organization#> .
@prefix agent-shape: <https://solidproject.org/shapes/agent#> .

agent-shape:AgentShape
    a sh:NodeShape ;
    sh:targetClass foaf:Agent ;

    sh:xone (
        [ sh:node person-shape:PersonShape ]
        [ sh:node organization-shape:OrganizationShape ]
        [ sh:node software-agent-shape:SoftwareAgentShape ]
    ) .


