@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix prov: <http://www.w3.org/ns/prov#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <http://schema.org/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

@prefix email-shape: <https://solidproject.org/shapes/email#> .
@prefix telephone-shape: <https://solidproject.org/shapes/telephone#> .
@prefix address-shape: <https://solidproject.org/shapes/address#> .
@prefix person-shape: <https://solidproject.org/shapes/person#> .
@prefix software-agent-shape: <https://solidproject.org/shapes/software-agent#> .
@prefix organization-shape: <https://solidproject.org/shapes/organization#> .
@prefix agent-shape: <https://solidproject.org/shapes/agent#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .

# source https://github.com/SolidOS/contacts-pane/blob/main/src/ontology/forms.ttl

agent-shape:AgentShape
    a sh:NodeShape ;
    sh:targetClass foaf:Agent ;
    dct:created "2026-03-12"^^xsd:date ;
    vs:term_status "testing" ;
    rdfs:label "Agent Shape" ;
    rdfs:comment "SHACL shape representing an agent, which can be a person, organization, or software agent." ;

    sh:xone (
        [ sh:node person-shape:ContactDetailsPersonShape ]
        [ sh:node organization-shape:ContactDetailsOrganizationShape ]
        [ sh:node software-agent-shape:ContactSoftwareAgentShape ]
    ) .

