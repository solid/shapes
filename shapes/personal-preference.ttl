@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://solidproject.org/shapes/preference#> a sh:NodeShape ;
    rdfs:label "Basic Preferences Shape" ;
    rdfs:comment "SHACL shape representing the basic preferences form, including personal information privacy and user categorization.",
        "This shape allows additional properties beyond those defined above." ;
    sh:closed false ;
    sh:property [ rdfs:label "Personal Information Heading" ;
            rdfs:comment "Heading for the personal information section in the form." ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path <http://www.w3.org/ns/ui#contents> ],
        [ rdfs:label "Private Comment" ;
            rdfs:comment "Comment indicating that the personal information is private." ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path <http://www.w3.org/ns/ui#contents> ],
        [ rdfs:label "User Level" ;
            rdfs:comment "Classifier field to indicate the level or type of user." ;
            sh:class <http://www.w3.org/ns/solid/terms#User> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ] ;
    sh:targetClass <http://www.w3.org/ns/solid/terms#User> .

