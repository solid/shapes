@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <http://schema.org/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

@prefix email-shape: <https://solidproject.org/shapes/email#> .
@prefix telephone-shape: <https://solidproject.org/shapes/telephone#> .
@prefix address-shape: <https://solidproject.org/shapes/address#> .
@prefix organization-shape: <https://solidproject.org/shapes/Organization#> .



################################################################
# Source: https://github.com/SolidOS/contacts-pane/blob/main/src/ontology/organizationForm.ttl
################################################################

organization-shape:OrganizationContactShape
    a sh:NodeShape ;
    sh:targetClass vcard:Organization ;
    rdfs:label "Organization Shape" ;
    rdfs:comment "SHACL shape for validating organization contact and classification details." ;

    # Organization Name
    sh:property [
        sh:path schema:name ;
        sh:minCount 0 ;
        sh:datatype xsd:string ;
        sh:maxLength 200 ;
        rdfs:label "Organization Name" ;
        rdfs:comment "The official name of the organization."
    ] ;

    # Homepage URL
    sh:property [
        sh:path schema:url ;
        sh:minCount 0 ;
        sh:nodeKind sh:IRI ;
        rdfs:label "Homepage URL" ;
        rdfs:comment "The homepage or primary web address of the organization."
    ] ;

    # Organization Type / Classification
    sh:property [
        sh:path rdf:type ;
        sh:minCount 0 ;
        sh:nodeKind sh:IRI ;
        sh:in (
            schema:Corporation
            schema:EducationalOrganization
            schema:GovernmentOrganization
            schema:NGO
            schema:PerformingGroup
            schema:Project
            schema:SportsOrganization
        ) ;
        rdfs:label "Organization Type / Category" ;
        rdfs:comment "Classification of the organization as one of the predefined types."
    ] .





# - https://github.com/SolidOS/contacts-pane/blob/main/src/ontology/forms.ttl

organization-shape:OrganizationContactDetailedShape
    a sh:NodeShape ;
    sh:targetClass foaf:Organization ;
    rdfs:label "Organization Shape" ;
    rdfs:comment "SHACL shape defining data constraints for an organization " ;
    

    sh:property
        # Organization Name
        [ sh:path schema:name ;
          sh:minCount 1 ;
          sh:maxCount 1 ;
          rdfs:label "Organization Name" ;
          rdfs:comment "The official name of the organization."
        ],

        # Homepage
        [ sh:path schema:url ;
          sh:minCount 0 ;
          sh:maxCount 1 ;
          rdfs:label "Homepage URL" ;
          rdfs:comment "The homepage or primary website of the organization."
        ],

        # Organization Type / Classification
        [ sh:path rdf:type ;
          sh:minCount 1 ;
          rdfs:label "Organization Type" ;
          rdfs:comment "The classification or type of organization (e.g., interesting organization category)."
        ],

        # Addresses
        [ sh:path vcard:hasAddress ;
          sh:minCount 0 ;
          rdfs:label "Address" ;
          rdfs:comment "Physical addresses." ;
          sh:node address-shape:AddressShape;
        ],

        # Emails
        [ sh:path vcard:hasEmail ;
          sh:minCount 0 ;
          rdfs:label "Email Addresses" ;
          rdfs:comment "Email addresses." ;
          sh:node email-shape:EmailShape;
        ],

        # Telephones
        [ sh:path vcard:hasTelephone ;
          sh:minCount 0 ;
          rdfs:label "Telephone Numbers" ;
          rdfs:comment "Telephone numbers associated with the organization." ;
          sh:node telephone-shape:TelephoneShape;
        ],

        # Notes
        [ sh:path vcard:note ;
          sh:minCount 0 ;
          sh:maxCount 1 ;
          rdfs:label "Notes" ;
          rdfs:comment "General notes about the organization."
        ] .