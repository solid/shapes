@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://solidproject.org/shapes/webid#> a sh:NodeShape ;
    sh:description """The URL of the subject can be a Homepage on the web,
    their Solid-compatible WebId, or an RDF Id in open public data.""" ;
    sh:property [ sh:class rdfs:Class ;
            sh:in ( <http://www.w3.org/2006/vcard/ns#Home> <http://www.w3.org/2006/vcard/ns#Work> <http://www.w3.org/2006/vcard/ns#Homepage> <http://www.w3.org/2006/vcard/ns#WebId> <http://www.w3.org/2006/vcard/ns#PublicId> ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://www.w3.org/2006/vcard/ns#value> ;
            sh:pattern "^https?:" ] ;
    sh:targetObjectsOf <http://www.w3.org/2006/vcard/ns#url> .

