@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix cal:  <http://www.w3.org/2002/12/cal/ical#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .

@prefix meeting_shape: <https://solidproject.org/shapes/meeting#> .

meeting_shape:MeetingShape
    a sh:NodeShape ;
    sh:name "Meeting Shape" ;
    sh:description "Defines constraints for meeting instances including title, location, time, comments, and display color." ;
    sh:targetClass cal:Vevent ;
    dct:created "2026-03-12"^^xsd:date ;
    vs:term_status "testing" ;
    dc:source <https://github.com/SolidOS/meeting-pane/blob/main/src/meetingDetailsForm.ttl> ;
    prov:wasDerivedFrom <https://github.com/SolidOS/meeting-pane/blob/main/src/meetingDetailsForm.ttl> ;
    dct:references <http://www.w3.org/2002/12/cal/ical#Vevent> ; 
    sh:codeIdentifier "Meeting";
    
    sh:property [
        sh:path cal:summary ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:maxLength 256 ;
        sh:name "Meeting Title" ;
        sh:description "The name or summary of the meeting.";
        sh:codeIdentifier "summary";
    ] ;

    sh:property [
        sh:path cal:location ;
        sh:datatype xsd:string ;
        sh:maxLength 128 ;
        sh:maxCount 1 ;
        sh:name "Meeting Location" ;
        sh:description "The location where the meeting takes place.";
        sh:codeIdentifier "location";
    ] ;

    sh:property [
        sh:path cal:dtstart ;
        sh:datatype xsd:dateTime ;
        sh:name "Start Date/Time" ;
        sh:description "The start date and time of the meeting.";
        sh:codeIdentifier "startDate";
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path cal:dtend ;
        sh:datatype xsd:dateTime ;
        sh:name "End Date/Time" ;
        sh:description "The end date and time of the meeting.";
        sh:codeIdentifier "endDate";
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path cal:comment ;
        sh:datatype xsd:string ;
        sh:name "Comment" ;
        sh:description "Additional notes or comments about the meeting.";
        sh:codeIdentifier "comment";
        sh:maxCount 1 ;
    ]; 
     .


