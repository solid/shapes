@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix cal:  <http://www.w3.org/2002/12/cal/ical#> .
@prefix meeting-shape: <https://solidproject.org/shapes/meeting#> .


################################################################
# Meeting Shape
# SHACL data shapes extracted from the SolidOS meeting pane UI form definition
# Source: https://github.com/SolidOS/meeting-pane/blob/main/src/meetingDetailsForm.ttl
################################################################

meeting-shape:MeetingShape
    a sh:NodeShape ;
    rdfs:label "Meeting Shape"@en ;
    rdfs:comment "Defines constraints for meeting instances including title, location, time, comments, and display color."@en ;
    sh:targetClass cal:Vevent ;

    sh:property [
        sh:path cal:summary ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxLength 256 ;
        rdfs:label "Meeting Title"@en ;
        rdfs:comment "The name or summary of the meeting."@en
    ] ;

    sh:property [
        sh:path cal:location ;
        sh:datatype xsd:string ;
        sh:minCount 0 ;
        sh:maxLength 128 ;
        rdfs:label "Location"@en ;
        rdfs:comment "The location where the meeting takes place."@en
    ] ;

    sh:property [
        sh:path cal:dtstart ;
        sh:datatype xsd:dateTime ;
        sh:minCount 0 ;
        rdfs:label "Start Time"@en ;
        rdfs:comment "The start date and time of the meeting."@en
    ] ;

    sh:property [
        sh:path cal:dtend ;
        sh:datatype xsd:dateTime ;
        sh:minCount 0 ;
        rdfs:label "End Time"@en ;
        rdfs:comment "The end date and time of the meeting."@en
    ] ;

    sh:property [
        sh:path cal:comment ;
        sh:datatype xsd:string ;
        sh:minCount 0 ;
        rdfs:label "Comment"@en ;
        rdfs:comment "Additional notes or comments about the meeting."@en
    ] ;

     .


