@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://solidproject.org/shapes/chatchannel#> a sh:NodeShape ;
    rdfs:label "Chat Channel Shape" ;
    rdfs:comment "SHACL NodeShape describing the properties and constraints for a Solid Chat LongChat." ;
    sh:property [ rdfs:label "Type" ;
            rdfs:comment "Specifies that the node must be of type LongChat." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ;
            sh:value <http://www.w3.org/ns/pim/meeting#LongChat> ],
        [ rdfs:label "Author" ;
            rdfs:comment "The author of the chat channel." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dc:author ],
        [ rdfs:label "Title" ;
            rdfs:comment "The title of the chat channel." ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dc:title ],
        [ rdfs:label "Created Date" ;
            rdfs:comment "The creation date of the chat channel." ;
            sh:datatype xsd:dateTime ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dc:created ],
        [ rdfs:label "Shared Preferences" ;
            rdfs:comment "References user interface preferences shared in the chat." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://www.w3.org/ns/ui#sharedPreferences> ],
        [ rdfs:label "Participation" ;
            rdfs:comment "Indicates participants in the chat channel." ;
            sh:minCount 0 ;
            sh:path <http://www.w3.org/2005/01/wf/flow#participation> ] ;
    sh:targetClass <http://www.w3.org/ns/pim/meeting#LongChat> .

