@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://solidproject.org/shapes/meeting#> a sh:NodeShape ;
    rdfs:label "Meeting Settings Shape"@en ;
    rdfs:comment "Defines constraints for meeting tab configuration including label, target resource, view mode, and color."@en ;
    sh:property [ rdfs:label "Tab Color"@en ;
            rdfs:comment "UI background color for the meeting tab."@en ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path <http://www.w3.org/ns/ui#backgroundColor> ],
        [ rdfs:label "Tab Label"@en ;
            rdfs:comment "Label shown on the meeting tab."@en ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:maxLength 128 ;
            sh:minCount 0 ;
            sh:path rdfs:label ],
        [ rdfs:label "Target Resource"@en ;
            rdfs:comment "IRI of the resource associated with the meeting."@en ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:nodeKind sh:IRI ;
            sh:path <http://www.w3.org/ns/pim/meeting#target> ],
        [ rdfs:label "View Mode"@en ;
            rdfs:comment "Optional view mode configuration for advanced users."@en ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:maxLength 128 ;
            sh:minCount 0 ;
            sh:path <http://www.w3.org/ns/pim/meeting#view> ] .

<https://solidproject.org/shapes/meeting#> a sh:NodeShape ;
    rdfs:label "Meeting Shape"@en ;
    rdfs:comment "Defines constraints for meeting instances including title, location, time, comments, and display color."@en ;
    sh:property [ rdfs:label "Meeting Title"@en ;
            rdfs:comment "The name or summary of the meeting."@en ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:maxLength 256 ;
            sh:minCount 1 ;
            sh:path <http://www.w3.org/2002/12/cal/ical#summary> ],
        [ rdfs:label "Location"@en ;
            rdfs:comment "The location where the meeting takes place."@en ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:maxLength 128 ;
            sh:minCount 0 ;
            sh:path <http://www.w3.org/2002/12/cal/ical#location> ],
        [ rdfs:label "Start Time"@en ;
            rdfs:comment "The start date and time of the meeting."@en ;
            sh:datatype xsd:dateTime ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://www.w3.org/2002/12/cal/ical#dtstart> ],
        [ rdfs:label "End Time"@en ;
            rdfs:comment "The end date and time of the meeting."@en ;
            sh:datatype xsd:dateTime ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path <http://www.w3.org/2002/12/cal/ical#dtend> ],
        [ rdfs:label "Comment"@en ;
            rdfs:comment "Additional notes or comments about the meeting."@en ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path <http://www.w3.org/2002/12/cal/ical#comment> ],
        [ rdfs:label "Tab Color"@en ;
            rdfs:comment "UI background color associated with the meeting tab."@en ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path <http://www.w3.org/ns/ui#backgroundColor> ] ;
    sh:targetClass <http://www.w3.org/2002/12/cal/ical#Vevent> .

