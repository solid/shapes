@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix vcard-shape: <https://solidproject.org/shapes/vcard#> .

#################################################################
# Main vCard Shape
# The vCard shapes have been created with ref to the vCard format spec https://datatracker.ietf.org/doc/html/rfc6350
# Shapes are not based on prior work in SolidOS GitHub repositories
#################################################################

vcard-shape:VCardShape
    a sh:NodeShape ;
    sh:targetClass vcard:VCard ;

    rdfs:label "vCard Shape" ;
    rdfs:comment "RFC 6350 based vCard validation." ;

    sh:property [
        sh:path vcard:fn ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype rdf:langString ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:n ;
        sh:maxCount 1 ;
        sh:node vcard-shape:NameShape ;
        sh:nodeKind sh:BlankNode ;
    ] ;

    sh:property [
        sh:path vcard:hasEmail ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 3 ;
    ] ;

    sh:property [
        sh:path vcard:hasTelephone ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 3 ;
    ] ;

    sh:property [
        sh:path vcard:hasAddress ;
        sh:node vcard-shape:AddressShape ;
        sh:nodeKind sh:BlankNode ;
    ] ;

    sh:property [
        sh:path vcard:organization-name ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype rdf:langString ]
        ) ;
    ] ;
.

#################################################################
# Structured Name Shape
#################################################################

vcard-shape:NameShape
    a sh:NodeShape ;

    sh:property [
        sh:path vcard:family-name ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype rdf:langString ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:given-name ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype rdf:langString ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:additional-name ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype rdf:langString ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:honorific-prefix ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype rdf:langString ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:honorific-suffix ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype rdf:langString ]
        ) ;
    ] ;
.

#################################################################
# Address Shape
#################################################################

vcard-shape:AddressShape
    a sh:NodeShape ;

    sh:property [
        sh:path vcard:street-address ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype rdf:langString ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:extended-address ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype rdf:langString ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:locality ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype rdf:langString ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:region ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype rdf:langString ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:postal-code ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype rdf:langString ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:country-name ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype rdf:langString ]
        ) ;
    ] ;
.