@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .

@prefix vcard-shape: <https://solidproject.org/shapes/vcard#> .

vcard-shape:VCardShape
    a sh:NodeShape ;
    sh:targetClass vcard:VCard ;
    rdfs:label "vCard Shape" ;
    rdfs:comment "RFC 6350 based vCard validation." ;
    dct:created "2026-03-12"^^xsd:date ;
    vs:term_status "testing" ;
    dct:references <https://datatracker.ietf.org/doc/html/rfc6350> ;
    rdfs:comment "This shape validates vCard data according to the structure and properties defined in RFC 6350, ensuring that vCard instances conform to the expected format and constraints." ;

    sh:property [
        sh:path vcard:fn ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype xsd:string ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:n ;
        sh:maxCount 1 ;
        sh:node vcard-shape:NameShape ;
        sh:nodeKind sh:BlankNode ;
    ] ;

    sh:property [
        sh:path vcard:hasEmail ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 3 ;
    ] ;

    sh:property [
        sh:path vcard:hasTelephone ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 3 ;
    ] ;

    sh:property [
        sh:path vcard:hasAddress ;
        sh:node vcard-shape:AddressShape ;
        sh:nodeKind sh:BlankNode ;
    ] ;

    sh:property [
        sh:path vcard:organization-name ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype xsd:string ]
        ) ;
    ] ;
.

#################################################################
# Structured Name Shape
#################################################################

vcard-shape:NameShape
    a sh:NodeShape ;
    rdfs:label "vCard Name Shape" ;
    rdfs:comment "SHACL shape representing the structured name of a vCard individual." ;
    dct:created "2026-03-12"^^xsd:date ;
    vs:term_status "testing" ;
    dct:references <https://datatracker.ietf.org/doc/html/rfc6350> ;
    rdfs:comment "This shape validates vCard data according to the structure and properties defined in RFC 6350, ensuring that vCard instances conform to the expected format and constraints." ;



    sh:property [
        sh:path vcard:family-name ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype xsd:string ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:given-name ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype xsd:string ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:additional-name ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype xsd:string ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:honorific-prefix ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype xsd:string ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:honorific-suffix ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype xsd:string ]
        ) ;
    ] ;
.

#################################################################
# Address Shape
#################################################################

vcard-shape:AddressShape
    a sh:NodeShape ;
    rdfs:label "vCard Address Shape" ;
    rdfs:comment "SHACL shape representing the address details of a vCard individual." ;
    dct:created "2026-03-12"^^xsd:date ;
    vs:term_status "testing" ;
    dct:references <https://datatracker.ietf.org/doc/html/rfc6350> ;
    rdfs:comment "This shape validates vCard data according to the structure and properties defined in RFC 6350, ensuring that vCard instances conform to the expected format and constraints." ;


    sh:property [
        sh:path vcard:street-address ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype xsd:string ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:extended-address ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype xsd:string ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:locality ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype xsd:string ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:region ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype xsd:string ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:postal-code ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype xsd:string ]
        ) ;
    ] ;

    sh:property [
        sh:path vcard:country-name ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:string ]
            [ sh:datatype xsd:string ]
        ) ;
    ] ;
.