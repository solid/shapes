@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .

@prefix person-shape:  <https://solidproject.org/shapes/person#> .

person-shape:ContactDetailsPersonShape a sh:NodeShape ;
    rdfs:label "Person Shape" ;
    rdfs:comment "SHACL shape representing a person" ;
    sh:targetClass vcard:Individual ;  
    dct:created "2026-03-12"^^xsd:date ;
    vs:term_status "testing" ;
    dc:source <https://github.com/SolidOS/contacts-pane/blob/main/src/ontology/forms.ttl> ;
    prov:wasDerivedFrom <https://github.com/SolidOS/contacts-pane/blob/main/src/ontology/forms.ttl> ;
    sh:codeIdentifier "Person";
    
    sh:property [ 
        sh:path vcard:fn ;
        sh:minCount 0 ;
        rdfs:label "Full Name" ;
        sh:datatype xsd:string; 
        sh:codeIdentifier "fullName";
    ];

    sh:property [ 
        sh:path vcard:role ;
        sh:minCount 0 ;
        rdfs:label "Role" ;
        rdfs:comment "The role or job title of the person." ;
        sh:datatype xsd:string;
        sh:codeIdentifier "role";
    ];

    sh:property [ 
        sh:path vcard:organization-name ;
        sh:minCount 0 ;
        rdfs:label "Organization Name" ;
        rdfs:comment "The organization the person belongs to.";
        sh:datatype xsd:string; 
        sh:codeIdentifier "organizationName";
    ];

    sh:property [ 
        sh:path vcard:hasAddress ;
        sh:minCount 0 ;
        sh:node _:AddressShape;
        rdfs:label "Address" ;
        rdfs:comment "Address details" ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:codeIdentifier "address";
    ];

    sh:property [ 
        sh:path vcard:hasEmail ;
        sh:minCount 0 ;
        sh:node _:EmailWithTypeShape;
        rdfs:label "Emails" ;
        rdfs:comment "Email addresses of the contact." ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:codeIdentifier "email";
    ];

    sh:property [ 
        sh:path vcard:hasTelephone ;
        sh:node _:TelephoneShape ;
        rdfs:label "Telephones" ;
        rdfs:comment "Telephone numbers of the contact." ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:codeIdentifier "telephone";
    ];

    sh:property [ 
        sh:path vcard:bday ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:datatype xsd:date ;
        rdfs:label "Birthday" ;
        rdfs:comment "Date of birth" ;
        sh:codeIdentifier "dateOfBirth";
    ];

    sh:property [ 
        sh:path vcard:note ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        rdfs:label "Notes" ;
        rdfs:comment "General notes about the contact." ;
        sh:datatype xsd:string;
        sh:codeIdentifier "notes";
    ];
    .

person-shape:IssueTrackerPersonShape
    a sh:NodeShape ;
    rdfs:label "Person Shape" ;
    rdfs:comment "Defines constraints for an individual person in a group." ;
    dct:created "2026-03-12"^^xsd:date ;
    vs:term_status "testing" ;
    dc:source <https://github.com/SolidOS/issue-pane/blob/main/src/ontology/trackerSettingsForm.ttl> ;
    prov:wasDerivedFrom <https://github.com/SolidOS/issue-pane/blob/main/src/ontology/trackerSettingsForm.ttl> ;
    dct:referencedBy <https://solidproject.org/shapes/issue-tracker> ;
    rdfs:comment "Person shape used in issue tracker from core:PersonForm" ;
    sh:codeIdentifier "Person";


    sh:property [
        sh:path vcard:fn ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        rdfs:label "Person Name" ;
        rdfs:comment "The human-readable name of the person.";
        sh:codeIdentifier "fullName";
    ] ;
    sh:property [
        sh:path owl:sameAs ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:class vcard:Individual ;
        rdfs:label "Solid ID" ;
        rdfs:comment "The Solid WebID of the person, if available.";
        sh:codeIdentifier "solidId";
    ] .





person-shape:ContactPersonShape a sh:NodeShape ;
    rdfs:label "Person Shape" ;
    rdfs:comment "SHACL shape representing a person" ;
    sh:targetClass vcard:Individual ;  
    dct:created "2026-03-12"^^xsd:date ;
    vs:term_status "testing" ;
    dc:source <https://github.com/SolidOS/contacts-pane/blob/main/shapes/contacts-shapes.ttl> ;
    prov:wasDerivedFrom <https://github.com/SolidOS/contacts-pane/blob/main/shapes/contacts-shapes.ttl> ;
    sh:codeIdentifier "Person";
    
    sh:property [
	    sh:path rdf:type ;
        sh:value vcard:Individual;
        sh:mincount 1;
        sh:maxCount 1;
        sh:codeIdentifier "Individual";
	];

    sh:property [ 
        sh:path vcard:fn ;
        sh:minCount 0 ;
        sh:pattern ".* .*" ;
        rdfs:label "Full Name" ;
        sh:datatype xsd:string; 
        sh:codeIdentifier "fullName";
    ];

    sh:property [ 
        sh:path vcard:hasUID ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:pattern "^urn:uuid:" ;
        sh:codeIdentifier "identifier";
    ];

    sh:property [ 
        sh:path vcard:hasName ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:codeIdentifier "name";
    ];

    sh:property [ 
        sh:path vcard:hasPhoto ;
        sh:codeIdentifier "photo";
    ];

    sh:property [ 
        sh:path vcard:hasRelated ;
        sh:codeIdentifier "related";
    ];

    sh:property [ 
        sh:path vcard:url ;
        sh:codeIdentifier "url";
    ];

    sh:property [ 
        sh:path vcard:hasAddress ;
        sh:codeIdentifier "address";
    ];

    sh:property [ 
        sh:path vcard:bday ;
        sh:datatype xsd:dateTime;
        sh:maxCount 1;
        sh:codeIdentifier "dateOfBirth";
    ];

    sh:property [ 
        sh:path vcard:hasEmail ;
        sh:codeIdentifier "email";
        # source file does not link this to an email shape
    ];

    sh:property [ 
        sh:path vcard:hasTelephone;
        sh:codeIdentifier "telephone";
    ];

    sh:property [ 
        sh:path vcard:organization-name ;
        sh:datatype xsd:string;
        sh:maxCount 1;
        sh:codeIdentifier "organizationName";
    ];

    sh:property [ 
        sh:path vcard:role ;
        sh:minCount 0 ;
        sh:datatype xsd:string;
        sh:maxCount 1;
        rdfs:label "Role" ;
        rdfs:comment "The role or job title of the person." ;
        sh:codeIdentifier "role";
    ];

    sh:property [ 
        sh:path vcard:title;
        sh:datatype xsd:string;
        sh:maxCount 1;
        sh:codeIdentifier "title";
    ];

    sh:property [
		sh:path vcard:note;
        sh:datatype xsd:string;
        sh:maxCount 1;
        sh:codeIdentifier "notes";
	];

    sh:property [
		sh:path owl:sameAs; # Other IDs we have found for this person
        # But see also webids store as vcard:URI type vcard WebId
        sh:dataType vcard:Individual;
        sh:codeIdentifier "sameAs";
	];

    sh:property [
		sh:path vcard:inAddressBook; # Must be the same book
        a sh:BackwardLink;  # Must be stored at least in the book
        sh:minCount 1;
        sh:maxCount 1;   
        sh:codeIdentifier "inAddressBook";
	] .


    


_:TelephoneShape
    a sh:NodeShape ;
    sh:targetObjectsOf vcard:hasTelephone ;
    rdfs:label "Telephone Shape" ;
    rdfs:comment "SHACL shape for validating telephone numbers associated with a vCard contact, ensuring they conform to expected patterns and classifications." ;  
    dct:created "2026-03-12"^^xsd:date ;
    vs:term_status "testing" ;
    dc:source <https://github.com/SolidOS/contacts-pane/blob/main/src/ontology/forms.ttl> ;
    prov:wasDerivedFrom <https://github.com/SolidOS/contacts-pane/blob/main/src/ontology/forms.ttl> ;
    sh:codeIdentifier "Telephone";

    # Phone Type (optional, restricted to vCard types)
    sh:property [
        sh:path rdf:type ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:in ( vcard:Cell vcard:Home vcard:Work ) ;
        rdfs:label "Phone Type" ;
        rdfs:comment "The classification of the phone (cell, home, work)." ;
        sh:codeIdentifier "telephoneType";
    ] ;

    # Phone Number (required)
    sh:property [
        sh:path vcard:value ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        rdfs:label "Phone Number" ;
        rdfs:comment "The telephone number of the contact." ;
        sh:codeIdentifier "telephoneNumber";
    ] .

_:AddressShape
    rdfs:label "Address";
    sh:targetClass vcard:Address;
    a sh:NodeShape ;
    sh:codeIdentifier "Address";
    dct:created "2026-03-12"^^xsd:date ;
    vs:term_status "testing" ;
    prov:wasDerivedFrom <https://github.com/SolidOS/contacts-pane/blob/main/src/ontology/forms.ttl> ;
    dc:source <https://github.com/SolidOS/contacts-pane/blob/main/src/ontology/forms.ttl> ;
    

    sh:property [
        rdfs:label "Street Address";
        sh:path vcard:street-address ;
        sh:datatype xsd:string ;
        sh:maxLength 128 ;
        sh:maxCount 1;
        sh:codeIdentifier "streetAddress";

    ] ;

    sh:property [
        rdfs:label "Locality";
        sh:path vcard:locality ;
        sh:datatype xsd:string ;
        sh:maxLength 128 ;
        sh:maxCount 1;
        sh:codeIdentifier "locality";
    ] ;

    sh:property [
        rdfs:label "Postal Code";
        sh:path vcard:postal-code ;
        sh:datatype xsd:string ;
        sh:maxLength 25 ;
        sh:maxCount 1;
        sh:codeIdentifier "postalCode";
    ] ;

    sh:property [
        rdfs:label "Region";
        sh:path vcard:region ;
        sh:datatype xsd:string ;
        sh:maxLength 128 ;
        sh:maxCount 1;
        sh:codeIdentifier "region";
    ] ;

    sh:property [
        rdfs:label "Country Name";
        sh:path vcard:country-name ;
        sh:datatype xsd:string ;
        sh:maxLength 128 ;
        sh:maxCount 1;
        sh:codeIdentifier "countryName";
    ] .



_:EmailWithTypeShape
    a sh:NodeShape ;
    sh:targetObjectsOf vcard:hasEmail ;
    rdfs:label "Email Shape" ;
    rdfs:comment "SHACL shape describing the structure of an email contact node including its value and optional classification type." ;
    dct:created "2026-03-12"^^xsd:date ;
    vs:term_status "testing" ;
    dc:source <https://github.com/SolidOS/contacts-pane/blob/main/src/ontology/forms.ttl> ;
    prov:wasDerivedFrom <https://github.com/SolidOS/contacts-pane/blob/main/src/ontology/forms.ttl> ;
    dct:references <https://www.w3.org/2006/vcard/ns#> ; # references the vcard:hasEmail property, which is used to link an Individual to their email contact nodes, and the vcard:Email class, which is the expected type of those
    sh:codeIdentifier "Email";

    sh:property [
        sh:path vcard:value ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        rdfs:label "Email Address" ;
        rdfs:comment "The email address value (e.g., user@example.org).";
        sh:codeIdentifier "emailAddress";
    ] ;
    sh:property [
        sh:path rdf:type ;
        sh:minCount 0 ;
        rdfs:label "Email Type" ;
        rdfs:comment "The classification of the email (e.g., home or work).";
        sh:codeIdentifier "emailType";
    ] .