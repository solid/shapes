@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .

@prefix address-shape:  <https://solidproject.org/shapes/address#> .
@prefix email-shape: <https://solidproject.org/shapes/email#> .
@prefix telephone-shape: <https://solidproject.org/shapes/telephone#> .
@prefix person-shape:  <https://solidproject.org/shapes/person#> .

################################################################
# Person Contact Shape
# source: https://github.com/SolidOS/contacts-pane/blob/main/src/ontology/forms.ttl
################################################################

person-shape:ContactDetailsPersonShape a sh:NodeShape ;
    rdfs:label "Person Shape" ;
    rdfs:comment "SHACL shape representing a person" ;
    sh:targetClass vcard:Individual ;  
    
    sh:property [ 
        sh:path vcard:fn ;
        sh:minCount 0 ;
        rdfs:label "Full Name" ;
        sh:datatype xsd:string; 
    ];

    sh:property [ 
        sh:path vcard:role ;
        sh:minCount 0 ;
        rdfs:label "Role" ;
        rdfs:comment "The role or job title of the person." ;
        sh:datatype xsd:string;
    ];

    sh:property [ 
        sh:path vcard:organization-name ;
        sh:minCount 0 ;
        rdfs:label "Organization Name" ;
        rdfs:comment "The organization the person belongs to.";
        sh:datatype xsd:string; 
    ];

    sh:property [ 
        sh:path vcard:hasAddress ;
        sh:minCount 0 ;
        sh:node address-shape:AddressShape;
        rdfs:label "Address" ;
        rdfs:comment "Address details" ;
        sh:nodeKind sh:BlankNodeOrIRI ;
    ];

    sh:property [ 
        sh:path vcard:hasEmail ;
        sh:minCount 0 ;
        sh:node email-shape:EmailShape;
        rdfs:label "Emails" ;
        rdfs:comment "Email addresses of the contact." ;
        sh:nodeKind sh:BlankNodeOrIRI ;
    ];

    sh:property [ 
        sh:path vcard:hasTelephone ;
        sh:node telephone-shape:TelephoneShape ;
        rdfs:label "Telephones" ;
        rdfs:comment "Telephone numbers of the contact." ;
        sh:nodeKind sh:BlankNodeOrIRI ;
    ];

    sh:property [ 
        sh:path vcard:bday ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:datatype xsd:date ;
        rdfs:label "Birthday" ;
        rdfs:comment "Date of birth" 
    ];

    sh:property [ 
        sh:path vcard:note ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        rdfs:label "Notes" ;
        rdfs:comment "General notes about the contact." ;
        sh:datatype xsd:string;
    ];
    .


################################################################
# SHACL shape for a person/contact (from core:PersonForm)
# source shape used in issue tracker - see ./issue-tracker.ttl
# source https://github.com/SolidOS/issue-pane/blob/main/src/ontology/trackerSettingsForm.ttl
################################################################

person-shape:IssueTrackerPersonShape
    a sh:NodeShape ;
    rdfs:label "Person Shape" ;
    rdfs:comment "Defines constraints for an individual person in a group." ;

    sh:property [
        sh:path vcard:fn ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        rdfs:label "Person Name" ;
        rdfs:comment "The human-readable name of the person."
    ] ;
    sh:property [
        sh:path owl:sameAs ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:class vcard:Individual ;
        rdfs:label "Solid ID" ;
        rdfs:comment "The Solid WebID of the person, if available."
    ] .