@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://solidos.github.io/profile-pane/src/ontology/profileForm.ttl#PersonProfileShape> a sh:NodeShape ;
    rdfs:label "Person Profile Shape" ;
    rdfs:comment "SHACL shape for validating the structure of a personal profile in Solid, including name, pronouns, CV, skills, languages, and social accounts.",
        "This shape does not forbid additional properties beyond those defined above." ;
    sh:closed false ;
    sh:property [ rdfs:label "Nickname / Short name" ;
            rdfs:comment "A short name used for chats or informal references." ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path foaf:nick ],
        [ rdfs:label "Profile highlight color" ;
            rdfs:comment "Hex color code used for highlights in the public profile." ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path <http://www.w3.org/ns/solid/terms#profileHighlightColor> ],
        [ rdfs:label "Preferred subject pronoun" ;
            rdfs:comment "Preferred pronoun for subject role (he/she/they)." ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path <http://www.w3.org/ns/solid/terms#preferredSubjectPronoun> ],
        [ rdfs:label "Preferred object pronoun" ;
            rdfs:comment "Preferred pronoun for object role (him/her/them)." ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path <http://www.w3.org/ns/solid/terms#preferredObjectPronoun> ],
        [ rdfs:label "Preferred relative pronoun" ;
            rdfs:comment "Preferred relative pronoun (his/hers/theirs)." ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path <http://www.w3.org/ns/solid/terms#preferredRelativePronoun> ],
        [ rdfs:label "Role / Organization involvement" ;
            rdfs:comment "Memberships or roles in organizations, linking to past, current, or future roles." ;
            sh:minCount 0 ;
            sh:nodeKind sh:IRI ;
            sh:path org:member ],
        [ rdfs:label "Skills" ;
            rdfs:comment "Professional or personal skills of the individual, possibly linked to ESCO ontology." ;
            sh:minCount 0 ;
            sh:nodeKind sh:IRI ;
            sh:path <http://schema.org/skills> ],
        [ rdfs:label "Languages" ;
            rdfs:comment "Languages known by the individual, ordered by preference." ;
            sh:minCount 0 ;
            sh:nodeKind sh:IRI ;
            sh:path <http://schema.org/knowsLanguage> ],
        [ rdfs:label "Online accounts" ;
            rdfs:comment "Links to social media accounts such as Twitter, Mastodon, Github, LinkedIn, etc." ;
            sh:minCount 0 ;
            sh:nodeKind sh:IRI ;
            sh:path foaf:account ],
        [ rdfs:label "Profile background color" ;
            rdfs:comment "Hex color code used as background for the public profile." ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path <http://www.w3.org/ns/solid/terms#profileBackgroundColor> ] ;
    sh:targetClass foaf:Person .

